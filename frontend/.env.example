# GitHub OAuth (required for real authentication)
# Create a GitHub OAuth App: https://github.com/settings/developers
# Set Authorization callback URL to: http://localhost:3000/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# NextAuth secret (required for real authentication)
# Generate with: npx auth secret
AUTH_SECRET=

# Auth mode: set to "real" when using GitHub OAuth, omit or set "mock" for dev
# Must be NEXT_PUBLIC_ for Turbopack client-side inlining
NEXT_PUBLIC_AUTH_MODE=real

# ===== Coinbase CDP x402 Facilitator (Server Only) =====
# Get credentials at https://portal.cdp.coinbase.com
CDP_X402_URL=https://api.cdp.coinbase.com/platform/v2/x402
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
# 0.001 USDC (USDC has 6 decimals) = "1000"
BASE_X402_PRICE_AMOUNT=1000
BASE_MERCHANT_ADDRESS=

# ===== Agent Identity =====
NEXT_PUBLIC_AGENT_DID=did:ain:learner.eth/claude-tutor/v1

# ===== Cogito Agent (A2A) =====
NEXT_PUBLIC_COGITO_URL=https://cogito.ainetwork.ai

# ===== Web Terminal Backend (K8s) =====
# Demo server — set this to enable real Claude Code terminal
NEXT_PUBLIC_TERMINAL_API_URL=http://<PUBLIC_IP>:31000

# ===== Azure OpenAI (Server Only) =====
# Used by /api/courses/*/validate routes for LLM-based answer checking.
# Create a resource at https://portal.azure.com, deploy a GPT model, and
# copy the values from "Keys and Endpoint" + "Deployments".
AZURE_OPENAI_ENDPOINT=https://<resource-name>.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=<deployment-name>
AZURE_OPENAI_API_VERSION=2024-10-21
# Optional — informational only; actual routing uses DEPLOYMENT above.
AZURE_OPENAI_MODEL=gpt-4o-mini
